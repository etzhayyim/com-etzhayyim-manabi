  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605261045. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "All curriculum content open-source (Apache 2.0 + Charter Rider) on IPFS",
      "G2": "No advertising / sponsored content / commercial-product placement",
      "G3": "No algorithmic addiction (no streaks/rewards/FOMO/leaderboards/badges-as-status)",
      "G4": "Charter alignment — Council Lv6+ ≥3 per module: multi-gen + anti-individualism + Wellbecoming + non-eschatology",
      "G5": "Multilingual — minimum EN + JA; expand at ≥10-adherent-per-language threshold",
      "G6": "Zero data collection on minors — aggregate-only attestations + 30-day rotating pseudonym DID",
      "G7": "Anti-credentialism — no degrees/transcripts/GPA; only skillAttestation",
      "G8": "No proprietary curriculum — CC-BY-SA or Apache 2.0 + Rider only",
      "G9": "No for-profit textbook royalties — TitheRouter 10% to Public Fund; never purchase-gated",
      "G10": "No examination-as-coercion — self-paced demonstration; no proctoring; no ID-gating",
      "G11": "Lifelong — no age-out, no age-floor except minor privacy G6",
      "G12": "No political indoctrination — comparative governance only; no electoral mobilization",
      "G13": "Inquiry-based pedagogy — ≥30% learner-led per module",
      "G14": "Family/cultural transmission primary; comparative-religion mandated (etzhayyim included)"
    }
  },
  "nonGoals": {
    "description": "10 explicitly excluded scopes",
    "goals": {
