[{:db/id -1, :lex.learningSessionAttestation/lexicon 1, :lex.learningSessionAttestation/id "com.etzhayyim.manabi.learningSessionAttestation", :lex.learningSessionAttestation/defs "{:main {:type \"record\", :key \"tid\", :record {:type \"object\", :required [\"sessionId\" \"learnerAgeBucket\" \"moduleId\" \"completionFraction\"], :properties {:sessionId {:type \"string\", :description \"unique session identifier\"}, :learnerAgeBucket {:type \"string\", :enum [\"minor\" \"adult\"], :description \"discriminator: enforces G6 aggregate-only for minors\"}, :moduleId {:type \"string\", :description \"curriculum module (e.g. 'literacy-phonemic-awareness')\"}, :sessionDurationMinutes {:type \"integer\", :description \"total session time; permitted for aggregate (G6)\"}, :completionFraction {:type \"number\", :description \"0.0 to 1.0 progress through module; permitted for aggregate (G6)\"}, :performancePercentile {:type \"integer\", :description \"only if learnerAgeBucket='adult'; forbidden for minors (G6)\"}, :errorLogSummary {:type \"string\", :description \"only if learnerAgeBucket='adult'; forbidden for minors (G6)\"}}}}}"}]