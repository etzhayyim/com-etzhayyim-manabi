;; manabi 学び — learner-session cell (datalog, kotoba runtime)
;; ADR-2605261045 · Phase 2 scaffold
{:cell/id "learner-session"
 :cell/glyph "学"
 :cell/kind :datalog
 :cell/runtime :kotoba
 :cell/doc "Learning session coordination on kotoba Datom. Tracks per-session aggregate data (sessionDuration, moduleId, completionFraction). Minor-specific sessions store only aggregate (G6 structurally enforced). Replaces legacy Python session tracking."
 :cell/gates ["G6"]
 :cell/kotoba
 {:reads [:learner/did :learner/age-bucket :module/id]
  :writes [:learner-session/id :learner-session/learner-did :learner-session/module-id
           :learner-session/duration-minutes :learner-session/completion-fraction]}}
