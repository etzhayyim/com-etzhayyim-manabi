;; manabi 学び — literacy cell (langgraph, WASM runtime)
;; ADR-2605261045 · Phase 2 scaffold
{:cell/id "literacy"
 :cell/glyph "読"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_literacy"
 :cell/doc "Reading + writing path progression. Learner self-paces through guided discovery (G13: ≥30% learner-led). Content on IPFS (G1). Anti-addiction UX enforced structurally (G3). Minor attestations aggregate-only (G6)."
 :cell/state-graph
 {:nodes [:intro :phonemic-awareness :decoding :fluency :comprehension :writing-mechanics :written-expression]
  :entry :intro
  :edges [[:intro :phonemic-awareness] [:phonemic-awareness :decoding]
          [:decoding :fluency] [:fluency :comprehension]
          [:comprehension :writing-mechanics] [:writing-mechanics :written-expression]
          [:written-expression :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G3" "G6" "G13"]
 :cell/kotoba
 {:reads [:learner/did :module/content-cid :learner/age-bucket]
  :writes [:learner-session/literacy-stage :learner-session/completion-fraction :learner-session/duration-minutes]}}
