          [:addition-subtraction :multiplication-division] [:multiplication-division :fractions]
          [:fractions :decimals] [:decimals :algebra]
          [:algebra :geometry] [:geometry :calculus]
          [:calculus :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G3" "G6" "G13"]
 :cell/kotoba
 {:reads [:learner/did :module/content-cid :learner/age-bucket]
  :writes [:learner-session/numeracy-stage :learner-session/completion-fraction :learner-session/duration-minutes]}}
